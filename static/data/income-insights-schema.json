{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Income Insights Transaction Schema",
  "description": "Schema for income/debt tracking transactions. All monetary values in VND.",
  "type": "object",
  "required": ["transactions", "version"],
  "properties": {
    "version": {
      "type": "integer",
      "description": "Schema version for migration support.",
      "minimum": 1
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of last update."
    },
    "transactions": {
      "type": "array",
      "description": "Array of financial transaction records.",
      "items": {
        "type": "object",
        "required": ["sequence", "income", "debt", "day", "month", "year"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier (UUID or nanoid)."
          },
          "sequence": {
            "type": "integer",
            "description": "User-defined sequence number.",
            "minimum": 1
          },
          "income": {
            "type": "number",
            "description": "Income amount in VND. Must be >= 0.",
            "minimum": 0
          },
          "incomeLabel": {
            "type": "string",
            "description": "Label/category for the income entry."
          },
          "debt": {
            "type": "number",
            "description": "Debt/expense amount in VND. Stored as negative value. Must be <= 0.",
            "maximum": 0
          },
          "debtLabel": {
            "type": "string",
            "description": "Label/category for the debt/expense entry."
          },
          "subTotal": {
            "type": "number",
            "description": "Computed field: income + debt. Read-only in UI."
          },
          "transactionType": {
            "type": "string",
            "description": "Method or classification of the transaction."
          },
          "route": {
            "type": "string",
            "description": "Payment route or source/destination."
          },
          "remark": {
            "type": "string",
            "description": "Additional notes or remarks."
          },
          "date": {
            "type": "string",
            "format": "date",
            "description": "Computed field: ISO date (YYYY-MM-DD) derived from year/month/day. Read-only in UI."
          },
          "day": {
            "type": "integer",
            "description": "Day of the month (1-31).",
            "minimum": 1,
            "maximum": 31
          },
          "month": {
            "type": "integer",
            "description": "Month (1-12).",
            "minimum": 1,
            "maximum": 12
          },
          "year": {
            "type": "integer",
            "description": "Year (e.g., 2026).",
            "minimum": 2020,
            "maximum": 2100
          }
        }
      }
    }
  }
}
