{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Expense Management Transaction Schema",
  "description": "Schema for expense tracking transactions.",
  "type": "object",
  "required": [
    "transactions",
    "version"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "transactions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "sequence",
          "income",
          "expense",
          "expenseLabel",
          "day",
          "month",
          "year"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "sequence": {
            "type": "integer",
            "minimum": 1
          },
          "income": {
            "type": "number",
            "minimum": 0
          },
          "expense": {
            "type": "number",
            "minimum": 0
          },
          "expenseLabel": {
            "type": "string"
          },
          "expenseType": {
            "type": "string"
          },
          "transactionType": {
            "type": "string"
          },
          "route": {
            "type": "string"
          },
          "bankRoute": {
            "type": "string"
          },
          "remark": {
            "type": "string"
          },
          "date": {
            "type": "string",
            "format": "date"
          },
          "day": {
            "type": "integer",
            "minimum": 1,
            "maximum": 31
          },
          "month": {
            "type": "integer",
            "minimum": 1,
            "maximum": 12
          },
          "year": {
            "type": "integer",
            "minimum": 2020,
            "maximum": 2100
          }
        }
      }
    }
  }
}
