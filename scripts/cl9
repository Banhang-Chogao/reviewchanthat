#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

BRANCH="feat/cl9-$(date +%s)"
GIT_TOKEN="${GIT_TOKEN:-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}"

echo "=== cl9: Smart Deployment ==="

# 1. Kiểm tra working tree
if ! git diff --quiet HEAD; then
  echo "[1/6] Uncommitted changes detected."
else
  echo "[1/6] No changes — creating dummy diff for PR."
  echo "" >> README.md
fi

# 2. Build Hugo
echo "[2/6] Building Hugo..."
if ! hugo --minify 2>/dev/null; then
  echo "ERROR: Hugo build failed. Fix errors and try again."
  exit 1
fi

# 3. QA
echo "[3/6] Running QA..."
python scripts/qa_blog.py || {
  echo "ERROR: QA failed. Fix errors and try again."
  exit 1
}
python scripts/normalize_frontmatter.py || true

# 4. Commit
echo "[4/6] Committing..."
git checkout -b "$BRANCH"
git add -A
git commit -m "cl9: auto deploy $(date '+%Y-%m-%d %H:%M')" || echo "Nothing to commit."

# 5. Push
echo "[5/6] Pushing..."
git remote set-url origin "https://Banhang-Chogao:${GIT_TOKEN}@github.com/Banhang-Chogao/reviewchanthat.git"
git push origin "$BRANCH" 2>/dev/null || {
  echo "Push failed; retrying with token..."
  git push origin "$BRANCH"
}

# 6. PR
echo "[6/6] Creating PR..."
PR_JSON=$(curl -sf -X POST \
  -H "Authorization: token ${GIT_TOKEN}" \
  -H "Accept: application/vnd.github+json" \
  https://api.github.com/repos/Banhang-Chogao/reviewchanthat/pulls \
  -d "{\"title\":\"cl9: auto deploy $(date '+%Y-%m-%d %H:%M')\",\"head\":\"${BRANCH}\",\"base\":\"main\",\"body\":\"Auto PR by cl9.\"}") || {
  echo "PR creation failed (maybe no diff)."
  git checkout main
  git branch -D "$BRANCH"
  git remote set-url origin "https://github.com/Banhang-Chogao/reviewchanthat.git"
  exit 0
}

PR_URL=$(echo "$PR_JSON" | python3 -c "import sys,json; print(json.load(sys.stdin).get('html_url','unknown'))")
echo "PR: $PR_URL"

# Cleanup: về main
git checkout main
git remote set-url origin "https://github.com/Banhang-Chogao/reviewchanthat.git"

echo "=== cl9: Done ==="
