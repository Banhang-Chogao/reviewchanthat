public/
.hugo_build.lock
*.swp
*.swo
.DS_Store
.dev.vars
.dev.vars.*

# cl0: private artifacts (never publish)
.artifacts/

# Private content quality reports (never publish)
reports/

# Python cache
__pycache__/
*.pyc

# API keys
.env

# Local SSL certs (hugo server --tlsAuto)
cert.pem
key.pem

# Auto-generated image candidates
data/image-candidates/

# content-direction.json is tracked so Hugo Pages builds always have report data.
# Regenerated by scripts/content_direction.py + .github/workflows/content-direction.yml
# and also refreshed during deploy before hugo.
# Generated hero images (Part 2)
static/images/posts/*.webp
static/images/posts/*.png

# Auto-generated QA reports
data/compliance-report.json
